{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/content/**",
              "components/feedback/**",
              "components/forms/**",
              "components/media/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|drip|icon|iconPosition|disabled|href|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, drip, icon, iconPosition, disabled, href, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|light|outline-navy)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'light' | 'outline-navy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='iconPosition'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<Button> iconPosition must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|hoverLift|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, hoverLift, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:surface|glass)$/]",
        "message": "<Card> variant must be one of 'surface' | 'glass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<FooterLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='ImagePlaceholder'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|ratio|gradient|style|key|ref|className|style|children)$/]",
        "message": "<ImagePlaceholder> doesn't accept that prop. Declared props: label, ratio, gradient, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ImagePlaceholder'] > JSXAttribute[name.name='ratio'] > Literal[value!=/^(?:square|video|portrait|wide)$/]",
        "message": "<ImagePlaceholder> ratio must be one of 'square' | 'video' | 'portrait' | 'wide'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|type|label|required|error|placeholder|options|rows|value|onChange|id|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: as, type, label, required, error, placeholder, options, rows, value, onChange, id."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|select|textarea)$/]",
        "message": "<Input> as must be one of 'input' | 'select' | 'textarea'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|tel|date)$/]",
        "message": "<Input> type must be one of 'text' | 'email' | 'tel' | 'date'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LoadingScreen'] > JSXAttribute > JSXIdentifier[name!=/^(?:visible|key|ref|className|style|children)$/]",
        "message": "<LoadingScreen> doesn't accept that prop. Declared props: visible."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|subtitle|align|inverse|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, title, subtitle, align, inverse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionHeading> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|value|suffix|label|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: icon, value, suffix, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
